{
  "manifest_version": 3,
  "name": "밑줄 카페 도우미",
  "version": "1.2",
  "description": "방문한 게시글 표시",

  "permissions": [
    "storage"
  ],

  "host_permissions": [
    "https://cafe.naver.com/*"
  ],

  "icons": {
    "128": "icon128.png"
  },

  "action": {
    "default_title": "밑줄 카페 도우미"
  },

  "content_scripts": [
    {
      "matches": [
        "https://cafe.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
